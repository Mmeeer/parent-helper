      "bundleIdentifier": "com.parenthelper.parent"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#4A90D9"
      },
      "package": "com.parenthelper.parent"
    },
    "plugins": [
      "expo-secure-store"
    ]
  }
}
