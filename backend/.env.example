# =============================================================================
# Parent Helper Backend - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------

# Port the Express server listens on
PORT=3000

# Environment mode: "development" or "production"
# In development, password reset codes are returned in API responses.
# In production, they are only sent via email.
NODE_ENV=development

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# MongoDB connection string (required)
MONGODB_URI=mongodb://localhost:27017/parent-helper

# -----------------------------------------------------------------------------
# Authentication (JWT)
# -----------------------------------------------------------------------------

# Secret key for signing access tokens (required — change in production!)
JWT_SECRET=your-secret-key-change-in-production

# Secret key for signing refresh tokens (required — change in production!)
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production

# Access token lifetime (default: 1h)
JWT_EXPIRES_IN=1h

# Refresh token lifetime (default: 7d)
JWT_REFRESH_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# Admin Account (for initial setup via POST /admin/seed)
# -----------------------------------------------------------------------------

# Admin email (default: admin@parenthelper.com)
ADMIN_EMAIL=admin@parenthelper.com

# Admin password (default: admin123456 — change in production!)
ADMIN_PASSWORD=admin123456
